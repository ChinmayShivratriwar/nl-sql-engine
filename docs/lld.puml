@startuml
skinparam backgroundColor #0d1117
skinparam defaultFontColor #e2e8f0
skinparam defaultFontSize 11
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 100

skinparam rectangle {
    BackgroundColor #0f172a
    BorderColor #3b82f6
    FontColor #e2e8f0
    BorderThickness 1.5
    RoundCorner 10
}

skinparam note {
    BackgroundColor #1e293b
    BorderColor #334155
    FontColor #94a3b8
}

skinparam arrow {
    Color #3b82f6
    FontColor #64748b
    FontSize 10
}

title NL-SQL Engine вЂ” Low Level Design\nSpring Boot 3.5 В· Spring AI 1.0 В· Java 21

actor "User\n(React UI вЂ” Vercel)" as User #1d4ed8

package "API Layer" #0f172a {
    rectangle "**NlSqlController**\n@RestController\n/api/v1/query\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nExtracts client IP\nDelegates to service" as Controller
}

rectangle "**RateLimiterService**\nBucket4j вЂ” Token Bucket\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n10 req / min / IP\nConcurrentHashMap<IP, Bucket>\n429 on breach" as RateLimiter #1a0a0a

package "Service Layer" #0f172a {
    rectangle "**NlSqlService**\n@Cacheable (Caffeine)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCore orchestrator\n500 entries В· 10min TTL\nCache key = question\nHIT в†’ <5ms В· MISS в†’ full pipeline" as NlSqlService #1a0a1a

    rectangle "**SchemaService**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDynamic schema extraction\ninformation_schema.tables\ninformation_schema.columns\nZero config вЂ” auto-discovers all tables" as SchemaService

    rectangle "**SqlExecutorService**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSQL safety + execution\nBlocks: DROP В· DELETE В· TRUNCATE\nBlocks multiple statements\nJdbcTemplate.queryForList()" as SqlExecutor
}

package "LLM Layer" #0f172a {
    rectangle "**LLMStrategyFactory**\nFactory Pattern\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nResolves provider from env\napp.llm.provider=groq|ollama\nZero code change to switch" as LLMFactory #1a1200

    interface "**LLMStrategy**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ngenerateSQL(prompt): String" as LLMStrategy

    rectangle "**OllamaIntegration**\n[LOCAL ONLY]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOllamaChatModel injection\ntemperature=0.0\nnumPredict=300\nMistral 7B / phi3:mini" as Ollama #0a0a0a

    rectangle "**GroqIntegration**\n[PRODUCTION]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOpenAiChatModel в†’ Groq URL\nllama-3.3-70b-versatile\nInjects LLMRateLimiter" as Groq #0a0a1a
}

package "Rate Limiting вЂ” LLM" #0f172a {
    interface "**LLMRateLimiter**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvalidateAndConsume(): void" as LLMRateLimiter

    rectangle "**GroqRateLimiter**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n25 req / min\n300 req / day\nAtomicInteger counters\nAuto-reset time windows" as GroqRateLimiter #1a0800
}

package "Infrastructure" #0f172a {
    database "**PostgreSQL**\nSupabase вЂ” Pooler Port 6543\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHikariCP connection pool\nsslmode=require\nemployees В· projects tables" as DB

    rectangle "**DataSourceConfig**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nReads DB_URL В· DB_USERNAME\nDB_PASSWORD from env\nHikariCP tuning" as DSConfig

    rectangle "**CacheConfig**\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCaffeine CacheManager\nmaximumSize=500\nexpireAfterWrite=10m\nrecordStats=true" as CacheConfig
}

' в”Ђв”Ђ Request flow в”Ђв”Ђ
User -[#3b82f6]-> Controller : POST /api/v1/query
Controller -[#ef4444]-> RateLimiter : tryConsume(ip)
RateLimiter -[#ef4444]-> Controller : 429 if exceeded
Controller -[#3b82f6]-> NlSqlService : processQuery(request)

' в”Ђв”Ђ Service flow в”Ђв”Ђ
NlSqlService -[#10b981]-> SchemaService : extractSchema()
NlSqlService -[#f59e0b]-> LLMFactory : getStrategy()
NlSqlService -[#10b981]-> SqlExecutor : execute(sql)
SqlExecutor -[#10b981]-> DB : JdbcTemplate query

' в”Ђв”Ђ LLM factory в”Ђв”Ђ
LLMFactory -[#f59e0b]-> LLMStrategy : returns
LLMStrategy <|.. Ollama : implements
LLMStrategy <|.. Groq : implements

' в”Ђв”Ђ LLM rate limiter в”Ђв”Ђ
Groq -[#f59e0b]-> LLMRateLimiter : validateAndConsume()
LLMRateLimiter <|.. GroqRateLimiter : implements

' в”Ђв”Ђ Infrastructure wiring в”Ђв”Ђ
DSConfig -[#475569]-> DB : configures
CacheConfig -[#6d28d9]-> NlSqlService : @Cacheable

' в”Ђв”Ђ Response в”Ђв”Ђ
NlSqlService -[#3b82f6]-> Controller : QueryResponse
Controller -[#3b82f6]-> User : JSON response\n{ sql, results, timeMs, fromCache }

note right of NlSqlService
  Cache HIT path:
  Controller в†’ NlSqlService в†’ return cached
  Skips LLM + DB entirely
  Response time < 5ms
end note

note right of Groq
  Provider switch:
  app.llm.provider=ollama в†’ local dev
  app.llm.provider=groq в†’ production
  No code changes needed
end note

note bottom of SqlExecutor
  Defense in depth:
  1. Prompt instructs LLM against destructive SQL
  2. SqlExecutorService blocks at runtime
end note
@enduml